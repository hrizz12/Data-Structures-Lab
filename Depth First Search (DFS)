#include <stdio.h>
#include <stdlib.h>

#define MAX 100

// Adjacency list node
struct Node {
    int vertex;
    struct Node* next;
};

struct Node* adjList[MAX];
int visited[MAX];

// Create a new node
struct Node* createNode(int v) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->vertex = v;
    newNode->next = NULL;
    return newNode;
}

// Add edge (directed)
void addEdge(int u, int v) {
    struct Node* newNode = createNode(v);
    newNode->next = adjList[u];
    adjList[u] = newNode;
}

// Sort adjacency list (so smaller nodes are visited first)
void sortList(int v) {
    struct Node *i, *j;
    for (i = adjList[v]; i != NULL; i = i->next) {
        for (j = i->next; j != NULL; j = j->next) {
            if (i->vertex > j->vertex) {
                int temp = i->vertex;
                i->vertex = j->vertex;
                j->vertex = temp;
            }
        }
    }
}

// DFS function
void DFS(int v) {
    visited[v] = 1;
    printf("%d ", v);

    struct Node* temp = adjList[v];
    while (temp != NULL) {
        if (!visited[temp->vertex]) {
            DFS(temp->vertex);
        }
        temp = temp->next;
    }
}

int main() {
    int V, E;
    scanf("%d %d", &V, &E);

    // Initialize
    for (int i = 0; i < V; i++) {
        adjList[i] = NULL;
        visited[i] = 0;
    }

    // Input edges
    for (int i = 0; i < E; i++) {
        int u, v;
        scanf("%d %d", &u, &v);
        addEdge(u, v);
    }

    // Sort adjacency lists
    for (int i = 0; i < V; i++) {
        sortList(i);
    }

    int start;
    scanf("%d", &start);

    DFS(start);

    return 0;
}
